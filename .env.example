# Copy to .env for local development: cp .env.example .env
# .env is gitignored; only this template is committed.

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
# Production database name (defaults to boilerplate_production):
# DB_NAME=boilerplate_production

# --- Rails runtime ---
# RAILS_ENV=production
# RAILS_LOG_TO_STDOUT=true
# RAILS_MAX_THREADS=5        # Puma threads per worker (also the DB pool size)
# WEB_CONCURRENCY=2          # Puma worker processes
# JOB_CONCURRENCY=1          # Solid Queue worker processes
# PORT=3000

# Secret key base for production (or use config/master.key / RAILS_MASTER_KEY):
# SECRET_KEY_BASE=

# --- Solid Queue dashboard (Mission Control, mounted at /jobs) ---
# Required in production to unlock the dashboard (HTTP basic auth):
# MISSION_CONTROL_JOBS_USER=admin
# MISSION_CONTROL_JOBS_PASSWORD=change-me
