<% content_for :title, "Forgot your password?" %>

<div class="mx-auto max-w-md">
  <h1 class="text-center text-2xl font-bold tracking-tight">Forgot your password?</h1>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name),
        html: { method: :post, class: "mt-6 space-y-4 rounded-lg bg-white p-6 shadow" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: "block text-sm font-medium text-gray-700" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "mt-1 block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
    </div>

    <%= f.submit "Send reset instructions",
          class: "w-full rounded-md bg-indigo-600 px-4 py-2 font-medium text-white hover:bg-indigo-500" %>
  <% end %>

  <div class="mt-4 space-y-1 text-center text-sm">
    <%= render "devise/shared/links" %>
  </div>
</div>
