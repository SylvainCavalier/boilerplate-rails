<% flash.each do |type, message| %>
  <% next if message.blank? %>
  <% styles = type.to_sym == :notice ? "bg-green-50 text-green-800 ring-green-600/20" : "bg-red-50 text-red-800 ring-red-600/20" %>
  <div class="mx-auto mt-4 w-full max-w-5xl px-4">
    <div class="rounded-md px-4 py-3 text-sm ring-1 ring-inset <%= styles %>" role="alert">
      <%= message %>
    </div>
  </div>
<% end %>
